    {
      "parameters": {
        "jsCode": "const startTime = $('Start Time').first().json.startTime;\nconst endTime = Date.now();\nconst duration_ms = endTime - startTime;\n\nconst allEmbeddingItems = $('OpenAI Embedding Request').all();\nconst tokens_used = allEmbeddingItems.reduce((sum, item) => \n  sum + (item.json.usage?.total_tokens || 0), 0);\n\nconst fileInfo = $('Webhook').first().binary.document;\nconst size_bytes = Math.round(parseFloat(fileInfo.fileSize) * 1024);\nconst ext = fileInfo.fileExtension;\n\nconst base64File = $('Webhook').first().binary.document.data;\n\nreturn [{\n  json: {\n    name: fileInfo.fileName,\n    source_type: ext,\n    size_bytes: size_bytes,\n    duration_ms: duration_ms,\n    tokens_used: tokens_used,\n    file_data: base64File\n  }\n}];"
      },
