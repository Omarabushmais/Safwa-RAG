      "parameters": {
        "jsCode": "const { read } = require('xlsx');\n\nconst binaryData = await this.helpers.getBinaryDataBuffer(0, 'document');\nconst workbook = read(binaryData);\n\nconst item = $input.first();\n\nreturn workbook.SheetNames.map((name, index) => ({ \n  json: { sheetName: name, sheetIndex: index },\n  binary: item.binary\n}));"
      },
