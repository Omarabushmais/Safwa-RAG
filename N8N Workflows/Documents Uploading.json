    {
      "parameters": {
        "jsCode": "const documentId = $('Insert Document').first().json.id;\nconst embeddings = $('OpenAI Embedding Request').first().json.data;\n\nlet texts = [];\ntry {\n  texts = $('Chunking and Batching').first().json.input;\n} catch(e) {\n  texts = $('Parse Rows').all().flatMap(item => item.json.input || []);\n}\n\nreturn texts.map((text, index) => {\n  return {\n    json: {\n      document_id: documentId,\n      chunk_text: text,\n      embedding: `[${embeddings[index].embedding.join(',')}]`\n    }\n  };\n});"
      },
