    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst sheetName = $('Loop Over Items').first().json.sheetName;\nconst chunks = [];\n\nif (items.length === 0) return [{ json: { input: [] } }];\n\n// 1. CLEANING: Remove any rows that are completely empty/null immediately\nconst cleanedItems = items.filter(item => {\n  const vals = Object.values(item.json).map(v => String(v || '').trim()).filter(v => v !== '' && v !== 'undefined');\n  return vals.length > 0;\n});\n\nif (cleanedItems.length === 0) return [{ json: { input: [] } }];\n\n// 2. ANALYZE the first valid item\nconst initialKeys = Object.keys(cleanedItems[0].json);\nconst firstRowValues = Object.values(cleanedItems[0].json).map(v => String(v || '').trim());\n\n// Filter \"active\" keys that aren't auto-generated empty placeholders\nconst activeKeys = initialKeys.filter(k => !k.startsWith('__EMPTY') && k !== 'undefined' && k.trim() !== '');\n\nlet description = '';\nlet headers = [];\nlet dataStartIndex = 0;\n\n// Detection Logic:\nif (activeKeys.length === 1 && cleanedItems.length > 1) {\n  // Situation: Key is description, Row 1 is Headers\n  description = activeKeys[0];\n  headers = firstRowValues;\n  dataStartIndex = 1;\n} else {\n  // Situation: No description, Keys are the Headers\n  description = '';\n  headers = initialKeys;\n  dataStartIndex = 0;\n}\n\nconst prefix = description ? `${sheetName} / ${description}` : sheetName;\n\n// 3. PROCESS ROWS\nfor (let i = dataStartIndex; i < cleanedItems.length; i++) {\n  const row = cleanedItems[i].json;\n  const currentValues = Object.values(row);\n\n  const pairs = headers.map((h, idx) => {\n    // Clean up header names\n    let headerName = (h.startsWith('__EMPTY') || h === 'undefined' || h === '') ? `Column ${idx + 1}` : h;\n    \n    // Get corresponding value\n    let val = String(currentValues[idx] || '').trim();\n    if (val === '' || val === 'undefined') val = 'NO VALUE FOUND';\n    \n    return `${headerName}: ${val}`;\n  }).join(' / ');\n\n  // Final check to ensure we aren't adding \"NO VALUE FOUND\" only rows\n  if (pairs.replace(/NO VALUE FOUND/g, '').replace(/[: /]/g, '').trim() === '') continue;\n\n  chunks.push(`${prefix} [${pairs}]`);\n}\n\n// 4. BATCH RESULTS\nconst batchSize = 100;\nconst results = [];\nfor (let i = 0; i < chunks.length; i += batchSize) {\n  results.push({ json: { input: chunks.slice(i, i + batchSize) } });\n}\n\nreturn results;\n"
      },
