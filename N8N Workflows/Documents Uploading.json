        "jsCode": "const mammoth = require('mammoth');\n\nconst binaryData = await this.helpers.getBinaryDataBuffer(0, 'document');\nconst result = await mammoth.extractRawText({ buffer: binaryData });\n\nreturn [{\n  json: {\n    text: result.value\n  }\n}];"
      },
